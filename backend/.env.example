# ============================================================================
# FitCheck AI Backend - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values

# Supabase Configuration
# Get these from: Supabase Dashboard > Settings > API Keys
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=fitcheck-images

# Pinecone Vector Database
# Get your API key from: Pinecone Console > API Keys
PINECONE_API_KEY=
PINECONE_INDEX_NAME=fitcheck-items
PINECONE_ENVIRONMENT=
PINECONE_DIMENSION=768

# ============================================================================
# AI Provider Configuration
# ============================================================================
# Supports multiple providers: OpenAI, or custom OpenAI-compatible proxy
# Users can configure their own keys in the app, or use system defaults below

# Default Provider: openai | custom
AI_DEFAULT_PROVIDER=custom

# Gemini is not a selectable chat/vision/image provider - these two are used
# only for server-side embeddings (google-genai SDK). Get a key from:
# Google AI Studio > API Keys
AI_GEMINI_API_KEY=
AI_GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI Configuration
# Get your API key from: OpenAI Platform > API Keys
AI_OPENAI_API_URL=https://api.openai.com/v1
AI_OPENAI_API_KEY=
AI_OPENAI_CHAT_MODEL=gpt-4o
AI_OPENAI_VISION_MODEL=gpt-4o
AI_OPENAI_IMAGE_MODEL=dall-e-3

# Custom Provider (OpenAI-compatible). Default: Agnes AI for chat, vision, images.
# Get a key from: https://platform.agnes-ai.com
AI_CUSTOM_API_URL=https://apihub.agnes-ai.com/v1
AI_CUSTOM_API_KEY=
AI_CUSTOM_CHAT_MODEL=agnes-2.0-flash
AI_CUSTOM_VISION_MODEL=agnes-2.0-flash
AI_CUSTOM_IMAGE_MODEL=agnes-image-2.1-flash
AI_CUSTOM_IMAGE_FALLBACK_MODEL=agnes-image-2.0-flash

# Optional: explicit LLM vs Image overrides (fall back to AI_CUSTOM_* when unset).
# Same host is typical for Agnes; split hosts are supported if needed.
OPENAI_LLM_URL=https://apihub.agnes-ai.com/v1
OPENAI_LLM_API_KEY=
OPENAI_LLM_MODEL=agnes-2.0-flash
OPENAI_LLM_VISION_MODEL=agnes-2.0-flash
OPENAI_IMAGE_URL=https://apihub.agnes-ai.com/v1
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=agnes-image-2.1-flash
# "chat" = response_modalities on /chat/completions | "images" = /images/generations
OPENAI_IMAGE_API_STYLE=images

# Rate Limits (per user per day)
AI_DAILY_EXTRACTION_LIMIT=100
AI_DAILY_GENERATION_LIMIT=50
AI_DAILY_EMBEDDING_LIMIT=500

# Encryption key for storing user API keys (generate with: openssl rand -hex 32)
AI_ENCRYPTION_KEY=

# Timeout Settings (seconds)
AI_CONNECT_TIMEOUT=5.0
AI_READ_TIMEOUT=120.0
AI_WRITE_TIMEOUT=30.0
AI_POOL_TIMEOUT=10.0

# Application Settings (Optional)
DEBUG=false
FRONTEND_URL=http://localhost:3000
ENABLE_SOCIAL_IMPORT=true
SOCIAL_IMPORT_MAX_CONCURRENT_JOBS=1
SOCIAL_IMPORT_MAX_PHOTOS_PER_JOB=2000
SOCIAL_IMPORT_AUTH_SESSION_TTL_MINUTES=120
SOCIAL_IMPORT_DISCOVERY_PAGE_SIZE=50
META_OAUTH_CLIENT_ID=
META_OAUTH_CLIENT_SECRET=

# CORS Origins (comma-separated list)
BACKEND_CORS_ORIGINS=https://www.fitcheckaiapp.com,https://fitcheckaiapp.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Stripe Configuration
# Get your keys from: Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
