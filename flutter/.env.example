# Flutter Environment Configuration
#
# Local development prefers this asset file (bundled via pubspec assets: - .env).
# Production / App Store builds should pass values via --dart-define (see
# flutter/scripts/build_ios_release.sh and .github/workflows/build-ios.yml).
# Only put publishable client keys here — never service-role or secret keys.
#
# Usage (dev):
#   cp .env.example .env   # then fill real values
#   flutter run
#
# Usage (release iOS):
#   export SUPABASE_URL=... SUPABASE_ANON_KEY=... POSTHOG_API_KEY=...
#   ./scripts/build_ios_release.sh

# Local development backend
API_BASE_URL=http://localhost:8000

# Production (use with dart-define or replace for release builds)
# API_BASE_URL=https://api.fitcheckaiapp.com

# Supabase (required) — anon/publishable key only
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# PostHog (optional product analytics — not used for advertising tracking)
POSTHOG_API_KEY=your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# Sentry crash reporting (optional)
SENTRY_DSN=your-sentry-dsn-here

# Monetization CTAs (paywall / Stripe). Defaults: OFF on iOS, ON elsewhere.
# PAYWALL_ENABLED=false
